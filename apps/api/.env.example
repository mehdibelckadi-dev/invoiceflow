# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000

# Database (PostgreSQL 16 + pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/lefse

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-min-32-chars-xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change-me-min-32-chars-yyyyyyyyyyyyyyyy
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Uanataca eIDAS (QTSP)
UANATACA_API_URL=https://api.uanataca.com
UANATACA_API_KEY=
UANATACA_CERTIFICATE_ID=

# AEAT Verifactu
AEAT_VERIFACTU_URL_SANDBOX=https://prewww1.aeat.es/wlpl/TIKE-CONT/ws/SuministroInformacion
AEAT_VERIFACTU_URL_PROD=https://www1.aeat.es/wlpl/TIKE-CONT/ws/SuministroInformacion
