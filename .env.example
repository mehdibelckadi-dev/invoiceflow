# ═══════════════════════════════════════════════════════
#  InvoiceFlow — Configuración completa
#  Copia este archivo a .env y rellena los valores
# ═══════════════════════════════════════════════════════

# ── Anthropic (requerido) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Tu empresa (mejora la extracción) ───────────────────
MY_COMPANY_NAME=Tu Empresa S.L.
MY_TAX_ID=B12345678

# ── Clerk — Auth (requerido para producción) ─────────────
# 1. Regístrate en clerk.com
# 2. Crea una aplicación
# 3. Copia las claves desde el dashboard
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ── Stripe — Pagos (requerido para cobrar) ───────────────
# 1. stripe.com → API keys
# 2. Crea 2 productos: Starter (9€) y Pro (19€)
# 3. Copia los Price IDs (no los Product IDs)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# ── Railway — Despliegue ─────────────────────────────────
# Railway inyecta PORT automáticamente, no lo cambies
HOST=0.0.0.0
# PORT se inyecta automáticamente en Railway

# ── Email inbound (Postmark) ─────────────────────────────
INBOUND_EMAIL_ADDRESS=facturas@inbound.tudominio.com
EMAIL_WEBHOOK_SECRET=tu-token-postmark
EMAIL_PROVIDER=postmark
# EMAIL_SENDER_ALLOWLIST=["@tuempresa.com"]

# ── Google Sheets (plan Pro) ─────────────────────────────
# GOOGLE_CREDENTIALS_FILE=credentials.json
# SPREADSHEET_ID=1BxiMVs0XRA5nF...
# SHEET_NAME=Facturas

# ── Carpeta vigilada (opcional) ──────────────────────────
# WATCH_FOLDER=/Users/tu-nombre/Downloads/Facturas

# ── Usuario por defecto para email/watch (single-user) ───
# En modo multi-tenant esto se gestiona por token de inbound
INBOUND_DEFAULT_USER_ID=default

# ── Email de solicitud de facturas (Resend) ───────────────────────────────────
# Recomendado para enviar emails de solicitud de factura
# resend.com → API Keys → crear clave
# RESEND_API_KEY=re_...
